// =============================================================================
// Asgardeo Pre-Flight — ANOMALY-DETECTION query set
// =============================================================================
// Companion to test-queries.kql. Those queries are *informational* (summarise by
// day, render a chart, eyeball it). The queries below are *self-judging*: each one
// returns rows ONLY when something is anomalous, so the pipeline can treat any
// non-empty result as a finding (no human chart-reading needed).
//
// Two techniques:
//   A. Native time-series anomaly detection — make-series + series_decompose_anomalies.
//      Learns the seasonal/level baseline from the look-back window and flags hours
//      that deviate (spike OR drop) beyond a sensitivity score.
//   B. Baseline-vs-recent — compare the last `recentWindow` against the trailing
//      baseline (new error signatures, per-tenant spikes/drops). Catches step changes
//      that a daily average would smear over.
//
// The `let` parameters at the top of each query mirror the pipeline parameters in
// pipelines/asgardeo-preflight.yaml — keep the two in sync. Tables are the test
// `_CL` tables (test-setup/03-upload-sample-logs.sh). For PROD swap to the built-in
// tables (Usage / AzureDiagnostics / ContainerLog / KubePodInventory) — the logic is
// identical, only the table/column suffixes change.
// =============================================================================


// ---------- 1. Ingestion-volume anomaly (spike OR drop) ----------
// param anomalySensitivity (default 1.5; lower = more sensitive). lookbackDays drives the window.
let sensitivity = 1.5;
let lookback    = 7d;
Usage_CL
| make-series VolGB = sum(Quantity_d / 1000.) default=0
    on TimeGenerated from ago(lookback) to now() step 1h
| extend (flag, score, baseline) = series_decompose_anomalies(VolGB, sensitivity)
| mv-expand TimeGenerated to typeof(datetime), VolGB to typeof(double),
            flag to typeof(long), score to typeof(double), baseline to typeof(double)
| where flag != 0
| project TimeGenerated, VolGB = round(VolGB, 2), baseline = round(baseline, 2),
          score = round(score, 2), direction = iff(flag > 0, "spike", "drop")
| order by TimeGenerated asc


// ---------- 2. Frontdoor traffic anomaly (spike OR drop) ----------
// A drop can mean an outage / DNS / cert problem; a spike can mean abuse or a noisy bot.
let sensitivity = 1.5;          // anomalySensitivity
let lookback    = 7d;           // lookbackDays
FrontdoorAccessLog_CL
| where Category_s =~ "FrontdoorAccessLog"
| make-series Requests = count() default=0
    on TimeGenerated from ago(lookback) to now() step 1h
| extend (flag, score, baseline) = series_decompose_anomalies(Requests, sensitivity)
| mv-expand TimeGenerated to typeof(datetime), Requests to typeof(long),
            flag to typeof(long), score to typeof(double), baseline to typeof(double)
| where flag != 0
| project TimeGenerated, Requests, baseline = round(baseline, 1),
          score = round(score, 2), direction = iff(flag > 0, "spike", "drop")
| order by TimeGenerated asc


// ---------- 3. Error-rate burst anomaly ----------
// Complements the static "errors/day > errorCountDailyThreshold" check: this catches a
// short, sharp burst (one bad hour) that a daily total would dilute below the threshold.
let sensitivity = 1.5;          // anomalySensitivity
let lookback    = 7d;           // lookbackDays
ContainerLog_CL
| where LogEntry_s has_cs ": ERROR"
| make-series Errors = count() default=0
    on TimeGenerated from ago(lookback) to now() step 1h
| extend (flag, score, baseline) = series_decompose_anomalies(Errors, sensitivity)
| mv-expand TimeGenerated to typeof(datetime), Errors to typeof(long),
            flag to typeof(long), score to typeof(double), baseline to typeof(double)
| where flag > 0                // only upward bursts matter for errors
| project TimeGenerated, Errors, baseline = round(baseline, 1), score = round(score, 2)
| order by TimeGenerated asc


// ---------- 4. Novel error signatures (regressions) ----------
// Error (class|message-prefix) signatures seen in the recent window but NEVER in the
// trailing baseline — i.e. a *new* failure mode, the classic "what broke since last week".
// param newErrorRecentHours (default 24).
let recentWindow = 24h;         // newErrorRecentHours
let lookback     = 7d;          // lookbackDays
ContainerLog_CL
| where TimeGenerated > ago(lookback)
| where LogEntry_s has_cs ": ERROR"
| parse LogEntry_s with * " : ERROR {" Class "}" Rest
| where isnotempty(Class)
| extend Signature = strcat(Class, " | ", substring(trim(@"\s+", tostring(Rest)), 0, 60))
| extend Window = iff(TimeGenerated > ago(recentWindow), "recent", "baseline")
| summarize recent = countif(Window == "recent"), baseline = countif(Window == "baseline") by Signature
| where baseline == 0 and recent > 0
| project Signature, recent
| order by recent desc


// ---------- 5. Per-tenant error spike ----------
// A tenant whose recent error count is >= spikeFactor x its own trailing daily average.
// Per-tenant so one noisy tenant trips even when the global error rate looks normal.
// param tenantErrorSpikeFactor (default 3).
let spikeFactor  = 3.0;         // tenantErrorSpikeFactor
let recentWindow = 24h;         // newErrorRecentHours
let lookback     = 7d;          // lookbackDays
ContainerLog_CL
| where TimeGenerated > ago(lookback)
| where LogEntry_s has_cs ": ERROR"
| parse LogEntry_s with * "Tenant: [" TenantName "]" *
| where isnotempty(TenantName)
| extend Window = iff(TimeGenerated > ago(recentWindow), "recent", "baseline")
| summarize recent = countif(Window == "recent"),
            baselinePerDay = toreal(countif(Window == "baseline")) / ((lookback - recentWindow) / 1d)
    by TenantName
| where baselinePerDay > 0 and recent > spikeFactor * baselinePerDay
| project TenantName, recent, baselinePerDay = round(baselinePerDay, 1),
          factor = round(recent / baselinePerDay, 1)
| order by factor desc


// ---------- 6. HTTP 5xx ratio anomaly ----------
// Hours where the share of 5xx responses exceeds a ceiling. Ratio (not count) so it
// stays meaningful regardless of overall traffic volume.
// param http5xxRatioPercentThreshold (default 5).
let ratioThreshold = 5.0;       // http5xxRatioPercentThreshold
let lookback       = 7d;        // lookbackDays
FrontdoorAccessLog_CL
| where Category_s =~ "FrontdoorAccessLog"
| where TimeGenerated > ago(lookback)
| extend code = toint(httpStatusCode_s)
| summarize total = count(), errors = countif(code >= 500) by bin(TimeGenerated, 1h)
| extend pct5xx = round(100.0 * errors / total, 2)
| where total > 0 and pct5xx > ratioThreshold
| project TimeGenerated, total, errors, pct5xx
| order by TimeGenerated asc


// ---------- 7. Endpoint latency spike ----------
// Endpoints whose p95 latency over the window exceeds the SLO ceiling.
// param apiLatencyThresholdSeconds (default 1.0; reused from the existing latency check).
let latThreshold = 1.0;         // apiLatencyThresholdSeconds
let lookback     = 7d;          // lookbackDays
FrontdoorAccessLog_CL
| where Category_s =~ "FrontdoorAccessLog"
| where TimeGenerated > ago(lookback)
| extend endpoint = extract(@"(/[^?]*)", 1, tostring(requestUri_s))
| where isnotempty(endpoint)
| summarize p95 = percentile(timeTaken_d, 95), avg = avg(timeTaken_d), n = count() by endpoint
| where p95 > latThreshold
| project endpoint, p95 = round(p95, 3), avg = round(avg, 3), n
| order by p95 desc


// ---------- 8. Per-tenant traffic drop (silent outage) ----------
// A tenant that was active in the baseline but whose recent traffic fell by >= N% —
// the per-tenant outage a global traffic chart hides.
// param trafficDropPercentThreshold (default 50).
let dropPercent  = 50.0;        // trafficDropPercentThreshold
let recentWindow = 24h;         // newErrorRecentHours
let lookback     = 7d;          // lookbackDays
FrontdoorAccessLog_CL
| where Category_s =~ "FrontdoorAccessLog"
| where TimeGenerated > ago(lookback)
| extend reqUri = tostring(requestUri_s)
| extend tenant_from_path = extract(@"/t/([^/]+)", 1, reqUri)
| extend custom_domain    = extract(@"https?://([^/:]+)", 1, reqUri)
| extend tenant = case(
        isnotempty(tenant_from_path), tenant_from_path,
        isnotempty(custom_domain) and custom_domain !contains "asgardeo.io", custom_domain,
        "")
| where isnotempty(tenant)
| extend Window = iff(TimeGenerated > ago(recentWindow), "recent", "baseline")
| summarize recent = countif(Window == "recent"),
            baselinePerDay = toreal(countif(Window == "baseline")) / ((lookback - recentWindow) / 1d)
    by tenant
| where baselinePerDay > 0 and recent < baselinePerDay * (1 - dropPercent / 100.0)
| project tenant, recent, baselinePerDay = round(baselinePerDay, 1),
          dropPct = round(100.0 * (baselinePerDay - recent) / baselinePerDay, 1)
| order by dropPct desc
